# Nginx reverse proxy config for Coral Dash self-hosted
#
# Prerequisites:
#   - SSL certificate (e.g., from Let's Encrypt / certbot)
#   - Replace coraldash.example.com with your domain
#   - Replace certificate paths with your actual paths
#
# Usage:
#   1. Copy to /etc/nginx/sites-available/coraldash
#   2. ln -s /etc/nginx/sites-available/coraldash /etc/nginx/sites-enabled/
#   3. sudo nginx -t && sudo systemctl reload nginx

server {
    listen 80;
    server_name coraldash.example.com;
    return 301 https://$server_name$request_uri;
}

server {
    listen 443 ssl http2;
    server_name coraldash.example.com;

    ssl_certificate /etc/letsencrypt/live/coraldash.example.com/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/coraldash.example.com/privkey.pem;

    # SSL settings
    ssl_protocols TLSv1.2 TLSv1.3;
    ssl_ciphers HIGH:!aNULL:!MD5;
    ssl_prefer_server_ciphers on;

    # Proxy settings
    location / {
        proxy_pass http://localhost:3000;
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection 'upgrade';
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_cache_bypass $http_upgrade;
    }
}
