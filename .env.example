# ============================================
# Coral Dash Self-Hosted Configuration
# ============================================

# Licence key (required) — UUID format, purchase at https://coraldash.com/self-hosting
# Example: xxxxxxxx-xxxx-4xxx-xxxx-xxxxxxxxxxxx
LICENSE_KEY=

# Self-hosted mode flag (required)
SELF_HOSTED=true

# Your domain/URL where Coral Dash will be accessible.
# For a LAN trial without a reverse proxy (v3.1.1+), use http://your-server-ip:3000
# and sign in with email/password. Must exactly match the address in the browser.
SITE_URL=https://coraldash.example.com

# ============================================
# Supabase / Database
# ============================================

# PostgreSQL password — MUST be URL-safe (letters and digits only), because it
# is embedded in postgres:// connection URLs. Characters like / + @ : # ? break
# the stack, so avoid base64 output. Generate with: openssl rand -hex 24
POSTGRES_PASSWORD=your-super-secret-postgres-password

# JWT secret for Supabase auth (min 32 characters)
# Generate with: openssl rand -base64 32
JWT_SECRET=your-super-secret-jwt-token-at-least-32-chars

# Generate by running: ./docker/generate-keys.sh
# (reads JWT_SECRET from this file; set it first)
ANON_KEY=
SERVICE_ROLE_KEY=

# ============================================
# Google OAuth (required for Google Sheets sync; optional for login)
# ============================================

# Required for Google Sheets sync. Also powers "Continue with Google" login.
# Login can alternatively use email/password (see below), but Sheets sync still
# needs these credentials.
# Create at https://console.cloud.google.com/apis/credentials
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=

# ============================================
# Email / SMTP (optional — for email/password login extras)
# ============================================

# Email/password signup works out of the box with NONE of these set — new
# accounts are auto-confirmed (GOTRUE_MAILER_AUTOCONFIRM=true in docker-compose).
#
# Configure SMTP ONLY if you want email confirmation on signup and "forgot
# password" reset emails. Works with any SMTP provider (Resend shown as example).
# After setting these, uncomment the matching GOTRUE_SMTP_* lines in
# docker-compose.yml and set GOTRUE_MAILER_AUTOCONFIRM to "false".
# SMTP_HOST=smtp.resend.com
# SMTP_PORT=465
# SMTP_USER=resend
# SMTP_PASS=your-smtp-password-or-api-key
# SMTP_SENDER_EMAIL=auth@yourdomain.com

# ============================================
# Optional Settings
# ============================================

# Restrict to a single email address (recommended for self-hosted)
ALLOWED_EMAIL=

# Cron schedule for auto-sync (default: daily at 6am UTC)
# Uses standard cron syntax: minute hour day month weekday
SYNC_SCHEDULE=0 6 * * *

# Cron secret for internal API auth
CRON_SECRET=your-cron-secret

# Trading 212 API integration (optional)
# Generate with: openssl rand -hex 32
TRADING212_ENCRYPTION_KEY=

# Precious Metals spot prices (optional) — metalpriceapi.com API key.
# Enables daily auto-valuation of precious-metal assets on the net-worth page.
# Bring your own free-tier key from https://metalpriceapi.com. If left blank,
# metals can still be added but won't be valued until a key is configured.
METALPRICE_API_KEY=

# ============================================
# Advanced (usually not needed)
# ============================================

# Internal Supabase URL override — the app uses this server-side for faster
# Docker-internal routing. The default (http://kong:8000) works out of the box.
# Only change this if you've customised the Docker network layout.
# SUPABASE_URL=http://kong:8000
